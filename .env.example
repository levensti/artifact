# ─── Postgres ──────────────────────────────────────────────────
# Both URLs come from Supabase → Connect (or your Postgres provider).
# Use the *pooler* host (`aws-0-<region>.pooler.supabase.com`) for both —
# the direct host (`db.<ref>.supabase.co`) is IPv6-only on Supabase's free
# tier and won't work from Vercel build/runtime.

# Transaction pooler — runtime queries (Prisma client). Append ?pgbouncer=true
# so Prisma disables prepared statements (transaction-mode pooler can't keep
# them across requests).
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Session pooler — used by `prisma migrate deploy` and friends. Same host
# and credentials, port 5432, no pgbouncer flag.
DIRECT_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"


# ─── Auth.js (NextAuth) ────────────────────────────────────────
# Random 32-byte secret used to sign session cookies. Generate with:
#   openssl rand -base64 32
# Rotate per environment (dev / preview / prod).
AUTH_SECRET=""

# Canonical URL Auth.js uses to build OAuth callback URIs. Only required
# locally if you're testing on a non-default host; default localhost dev
# auto-detects from the request.
#
# In production you MUST set this to the host that's registered in Google
# Cloud Console as the OAuth redirect URI — otherwise sign-in flows
# initiated from other hosts (e.g. the apex) will fail with
# `redirect_uri_mismatch`.
# AUTH_URL="http://localhost:3000"

# Google OAuth client (Cloud Console → APIs & Services → Credentials →
# OAuth client ID, type "Web application"). Add these as Authorized
# redirect URIs on the same client:
#   - http://localhost:3000/api/auth/callback/google
#   - https://<your-prod-host>/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""


# ─── Encryption-at-rest ────────────────────────────────────────
# 32 bytes base64-encoded. Generate with:
#   openssl rand -base64 32
# Used to encrypt API keys + inference profile secrets in the DB. Rotating
# this invalidates every encrypted value, so keep it stable per environment.
ENCRYPTION_KEY=""


# ─── Supabase Storage ──────────────────────────────────────────
# Project URL — looks like `https://<project-ref>.supabase.co` (NOT the
# `…storage.supabase.co/storage/v1/s3` endpoint).
SUPABASE_URL=""

# `service_role` key from Supabase → Settings → API. JWT format starting
# with `eyJ`. Server-only — never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=""

# Bucket name. Create it in Supabase → Storage → New bucket (private).
SUPABASE_BUCKET="learning-material"


# ─── Multi-host routing (production only) ──────────────────────
# Leave these unset for local dev. The proxy treats unknown hosts (incl.
# localhost) as the app subdomain by default.

# Comma-separated apex hostnames. The proxy rewrites `/` on these hosts to
# `/signup` (the marketing/sign-in surface), and 308-redirects every other
# path to `APP_HOST`.
# APEX_HOSTS="withartifact.com,www.withartifact.com"

# Bare hostname of the app subdomain — where the actual app + auth flow
# live. Used by the proxy for apex→app redirects.
# APP_HOST="app.withartifact.com"

# Cookie domain for Auth.js. Set to a leading-dot parent domain
# (`.withartifact.com`) so session/state cookies span apex + app subdomain
# — required for sign-in flows initiated on apex to complete on the app
# subdomain. Leave unset locally for default host-scoped cookies.
# AUTH_COOKIE_DOMAIN=".withartifact.com"
