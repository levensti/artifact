// Artifact persistent store. All domain rows are scoped by `userId` and
// cascade-deleted when the owning user disappears.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/* ── Auth.js (NextAuth) ────────────────────────────────────────── */

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?

  accounts Account[]
  sessions Session[]

  reviews           Review[]
  deepDives         DeepDive[]
  wikiPages         WikiPage[]
  wikiPageSources   WikiPageSource[]
  wikiBacklinks     WikiBacklink[]
  wikiRevisions     WikiRevision[]
  apiKeys           ApiKey[]
  inferenceProfiles InferenceProfile[]
  preferences       UserPreferences?
  pdfBlobs          PdfBlob[]
  parsedPapers      ParsedPaper[]
  shares            Share[]
  projects          Project[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @id
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

/* ── Domain ────────────────────────────────────────────────────── */

model Review {
  id         String   @id
  userId     String
  title      String
  arxivId    String?
  pdfPath    String? // PdfBlob id (no FK — PdfBlob may be deleted independently)
  sourceUrl  String?
  createdAt  DateTime
  updatedAt  DateTime
  importedAt DateTime?
  /// Token of the share this review was imported from. Stored, not
  /// enforced via FK — the share row may be revoked or the owner may have
  /// deleted their copy. Drives the "Imported from {Owner}" badge.
  importedFromShareToken String?
  /// Snapshot of the sharer's display name at import time. Captured so the
  /// badge survives the original sharer renaming, deleting their account,
  /// or revoking the share.
  importedFromName       String?

  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages      ReviewMessages?
  annotations   ReviewAnnotations?
  prerequisites Prerequisites?
  deepDives     DeepDive[]
  wikiSources   WikiPageSource[]
  shares        Share[]
  projects      ProjectReview[]

  @@index([userId, createdAt])
  @@index([userId, arxivId])
}

model ReviewMessages {
  id       String @id @default(cuid())
  reviewId String @unique
  messages Json
  review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
}

model ReviewAnnotations {
  id          String @id @default(cuid())
  reviewId    String @unique
  annotations Json
  review      Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
}

model Prerequisites {
  id       String @id @default(cuid())
  reviewId String @unique
  data     Json
  review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
}

model DeepDive {
  id          String   @id
  userId      String
  reviewId    String
  paperTitle  String
  arxivId     String
  topic       String
  explanation String
  createdAt   DateTime

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, reviewId])
}

model WikiPage {
  id        String   @id
  userId    String
  slug      String
  title     String
  content   String
  pageType  String
  createdAt DateTime
  updatedAt DateTime

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  sources   WikiPageSource[]
  backlinks WikiBacklink[]
  revisions WikiRevision[]
  shares    Share[]

  @@unique([userId, slug])
  @@index([userId, updatedAt])
  @@index([userId, pageType])
}

model WikiPageSource {
  id       String   @id @default(cuid())
  userId   String
  pageId   String
  reviewId String
  passage  String?
  addedAt  DateTime

  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  page   WikiPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  review Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@unique([pageId, reviewId])
  @@index([userId, reviewId])
}

model WikiBacklink {
  id         String @id @default(cuid())
  userId     String
  sourceId   String
  targetSlug String

  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  source WikiPage @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([sourceId, targetSlug])
  @@index([userId, targetSlug])
}

model WikiRevision {
  id        Int      @id @default(autoincrement())
  userId    String
  pageId    String
  slug      String
  title     String
  content   String
  pageType  String
  savedAt   DateTime

  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  page WikiPage @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId, id])
}

/// API key for an external service (LLM provider or tool). The `value`
/// column holds the encrypted secret; see src/server/crypto.ts. The
/// `provider` discriminator currently spans LLM providers ("anthropic",
/// "openai", "xai") and tool keys ("brave").
model ApiKey {
  id        String   @id @default(cuid())
  userId    String
  provider  String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
}

/// One named OpenAI- or Anthropic-compatible inference endpoint.
model InferenceProfile {
  id                String   @id @default(cuid())
  userId            String
  label             String
  kind              String
  baseUrl           String
  apiKey            String
  supportsStreaming Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// Per-user UI preferences. `selectedModel` holds the currently-selected
/// model as JSON because the Model shape is denormalized (id, label,
/// provider, modelId, optional profileId) and is never queried by field.
model UserPreferences {
  userId        String  @id
  selectedModel Json?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PdfBlob {
  id          String   @id
  userId      String
  name        String?
  storagePath String
  createdAt   DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ParsedPaper {
  id     String @id @default(cuid())
  userId String
  hash   String
  parsed Json

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, hash])
}

/// A shareable link pointing at one review or one wiki page. The token
/// is the primary key (cuid → ~128 bits, URL-safe) and `kind`
/// discriminates which FK is populated. `onDelete: Cascade` from Review
/// and WikiPage means deleting the underlying record automatically
/// invalidates all of its shares — no orphans, no manual cleanup.
model Share {
  token        String    @id @default(cuid())
  userId       String
  kind         String // "review" | "wiki"
  reviewId     String?
  wikiPageId   String?
  /// For wiki shares: how many `[[slug]]` hops to traverse when cloning
  /// linked pages. Default 0 (root only); user opts in to deeper sharing.
  wikiDepth    Int?
  createdAt    DateTime  @default(now())
  /// Soft-delete. Lookups filter on `revokedAt = null`.
  revokedAt    DateTime?
  /// Owner-facing telemetry. Cheap to maintain.
  lastAccessAt DateTime?
  accessCount  Int       @default(0)

  user   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  review Review?   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  page   WikiPage? @relation(fields: [wikiPageId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([reviewId])
  @@index([wikiPageId])
}

/// A user-scoped workspace that groups multiple reviews around a topic
/// or research thread. Membership is many-to-many via ProjectReview, so
/// the same paper can belong to several projects (e.g. a paper relevant
/// to both an "RLHF" project and a "preference modeling" project).
model Project {
  id          String    @id @default(cuid())
  userId      String
  name        String
  /// Stable URL slug, unique per user. Generated from `name` on create
  /// and disambiguated with a numeric suffix on collision.
  slug        String
  description String?
  /// Free-form project notes — markdown, jotted thoughts, open
  /// questions. Distinct from ProjectMessages (chat); this is the
  /// user's own scratchpad pinned to the project.
  notes       String?
  /// Optional accent color (e.g. hex string) for sidebar / card UI.
  color       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  /// Soft-archive. Archived projects stay visible behind a toggle but
  /// are excluded from the default list.
  archivedAt  DateTime?

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviews  ProjectReview[]
  messages ProjectMessages?

  @@unique([userId, slug])
  @@index([userId, updatedAt])
}

/// Cross-paper chat thread for a project. Mirrors the ReviewMessages
/// shape: a single Json blob keyed by projectId. Messages reference the
/// same `ChatMessage` JSON used in per-review chats so the renderer is
/// shared.
model ProjectMessages {
  id        String  @id @default(cuid())
  projectId String  @unique
  messages  Json
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

/// Membership: a review may belong to many projects. Cascades from both
/// sides so deleting a project or a review cleans up the join rows.
model ProjectReview {
  projectId String
  reviewId  String
  addedAt   DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  review  Review  @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@id([projectId, reviewId])
  @@index([reviewId])
}
