// Artifact persistent store. All domain rows are scoped by `userId` and
// cascade-deleted when the owning user disappears.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── Auth.js (NextAuth) ──────────────────────────────────────────

model User {
  id            String    @id @default(uuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?

  accounts Account[]
  sessions Session[]

  reviews           Review[]
  deepDives         DeepDive[]
  wikiPages         WikiPage[]
  wikiPageSources   WikiPageSource[]
  wikiBacklinks     WikiBacklink[]
  wikiRevisions     WikiRevision[]
  apiKeys           ApiKey[]
  inferenceProfiles InferenceProfile[]
  preferences       UserPreferences?
  pdfBlobs          PdfBlob[]
  parsedPapers      ParsedPaper[]
  pageMaps          PageMap[]
  shares            Share[]
  discoverQueries   DiscoverQuery[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @id
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// ── Domain ──────────────────────────────────────────────────────

model Review {
  id                     String    @id @default(uuid())
  userId                 String
  title                  String
  arxivId                String?
  pdfPath                String? // PdfBlob id (no FK — PdfBlob may be deleted independently)
  sourceUrl              String?
  createdAt              DateTime
  updatedAt              DateTime
  importedAt             DateTime?
  /// Token of the share this review was imported from. Stored, not
  /// enforced via FK — the share row may be revoked or the owner may have
  /// deleted their copy. Drives the "Imported from {Owner}" badge.
  importedFromShareToken String?
  /// Snapshot of the sharer's display name at import time. Captured so the
  /// badge survives the original sharer renaming, deleting their account,
  /// or revoking the share.
  importedFromName       String?
  /// Set when this review was started from a Discover recommendation.
  /// Unique because a recommendation produces at most one review (upstream
  /// dedup via createOrGetReview enforces "one review per arxivId" so the
  /// rec→review action only fires once). SetNull preserves the review when
  /// the underlying recommendation is purged.
  fromRecommendationId   String?   @unique

  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages           ReviewMessages?
  annotations        ReviewAnnotations?
  deepDives          DeepDive[]
  wikiSources        WikiPageSource[]
  shares             Share[]
  fromRecommendation Recommendation?    @relation(fields: [fromRecommendationId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([userId, arxivId])
}

model ReviewMessages {
  id       String @id @default(uuid())
  reviewId String @unique
  messages Json
  review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
}

model ReviewAnnotations {
  id          String @id @default(uuid())
  reviewId    String @unique
  annotations Json
  review      Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
}

model DeepDive {
  id          String   @id @default(uuid())
  userId      String
  reviewId    String
  paperTitle  String
  arxivId     String
  topic       String
  explanation String
  createdAt   DateTime

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, reviewId])
}

model WikiPage {
  id        String   @id @default(uuid())
  userId    String
  slug      String
  title     String
  content   String
  pageType  String
  createdAt DateTime
  updatedAt DateTime

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  sources   WikiPageSource[]
  backlinks WikiBacklink[]
  revisions WikiRevision[]
  shares    Share[]

  @@unique([userId, slug])
  @@index([userId, updatedAt])
  @@index([userId, pageType])
}

model WikiPageSource {
  id       String   @id @default(uuid())
  userId   String
  pageId   String
  reviewId String
  passage  String?
  addedAt  DateTime

  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  page   WikiPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  review Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@unique([pageId, reviewId])
  @@index([userId, reviewId])
}

model WikiBacklink {
  id         String @id @default(uuid())
  userId     String
  sourceId   String
  targetSlug String

  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  source WikiPage @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([sourceId, targetSlug])
  @@index([userId, targetSlug])
}

model WikiRevision {
  id       String   @id @default(uuid())
  userId   String
  pageId   String
  slug     String
  title    String
  content  String
  pageType String
  savedAt  DateTime

  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  page WikiPage @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId, savedAt])
}

/// API key for an external service (LLM provider or tool). The `value`
/// column holds the encrypted secret; see src/server/crypto.ts. The
/// `provider` discriminator currently spans LLM providers ("anthropic",
/// "openai", "xai") and tool keys ("brave").
model ApiKey {
  id        String   @id @default(uuid())
  userId    String
  provider  String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
}

/// One named OpenAI- or Anthropic-compatible inference endpoint.
model InferenceProfile {
  id                String   @id @default(uuid())
  userId            String
  label             String
  kind              String
  baseUrl           String
  apiKey            String
  supportsStreaming Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// Per-user UI preferences. `selectedModel` holds the currently-selected
/// model as JSON because the Model shape is denormalized (id, label,
/// provider, modelId, optional profileId) and is never queried by field.
model UserPreferences {
  userId        String @id
  selectedModel Json?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PdfBlob {
  id          String   @id @default(uuid())
  userId      String
  name        String?
  storagePath String
  createdAt   DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ParsedPaper {
  id     String @id @default(uuid())
  userId String
  hash   String
  parsed Json

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, hash])
}

/// Lightweight per-paper map from citation tokens (section/figure/table
/// numbers) to PDF page numbers. Produced by a small LLM call that runs on
/// every paper open (not gated on length), independent of the full
/// `ParsedPaper`. Powers chip click-to-scroll without requiring the
/// expensive full parse to have run.
model PageMap {
  id     String @id @default(uuid())
  userId String
  hash   String
  map    Json

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, hash])
}

/// A shareable link pointing at one review or one wiki page. The token
/// is the primary key (uuid v4 → 122 bits, URL-safe) and `kind`
/// discriminates which FK is populated. `onDelete: Cascade` from Review
/// and WikiPage means deleting the underlying record automatically
/// invalidates all of its shares — no orphans, no manual cleanup.
model Share {
  token        String    @id @default(uuid())
  userId       String
  kind         String // "review" | "wiki"
  reviewId     String?
  wikiPageId   String?
  /// For wiki shares: how many `[[slug]]` hops to traverse when cloning
  /// linked pages. Default 0 (root only); user opts in to deeper sharing.
  wikiDepth    Int?
  createdAt    DateTime  @default(now())
  /// Soft-delete. Lookups filter on `revokedAt = null`.
  revokedAt    DateTime?
  /// Owner-facing telemetry. Cheap to maintain.
  lastAccessAt DateTime?
  accessCount  Int       @default(0)
  /// Distinct successful imports. "Ever imported" — does not decrement
  /// when the recipient deletes their cloned copy.
  importCount  Int       @default(0)

  user   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  review Review?   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  page   WikiPage? @relation(fields: [wikiPageId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([reviewId])
  @@index([wikiPageId])
}

/// One Discover turn: the user types a query, the agent searches and
/// emits curated picks. The query row groups the recommendations the
/// agent produced and stores the agent's auxiliary notes (Plan/Filter
/// preamble) — short, optional, separate from the chat transcript which
/// is not persisted.
model DiscoverQuery {
  id        String   @id @default(uuid())
  userId    String
  query     String
  /// Auxiliary text the agent emitted alongside the picks (Plan bullets,
  /// Filter line). Optional; trimmed transcript that gives context for
  /// the picks without storing the full chat.
  notes     String?
  /// "running" while the agent stream is in flight, "complete" once the
  /// client finalizes with the parsed picks, "errored" if the stream
  /// failed before producing recommendations.
  status    String   @default("running")
  createdAt DateTime

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  recommendations Recommendation[]

  @@index([userId, createdAt])
}

/// One paper pick from a DiscoverQuery's curated list. The first-class
/// triage entity: the queue UI reads these rows directly. State is
/// encoded as nullable timestamps — `dismissedAt` for dismissed, the
/// existence of a Review with `fromRecommendationId = this.id` for
/// in-library, neither for queued.
model Recommendation {
  id          String    @id @default(uuid())
  queryId     String
  /// 1-indexed position in the agent's submit_picks list — its own
  /// best-to-acceptable ordering. Surfaced in the queue UI so the user
  /// sees what the agent considered the strongest match.
  rank        Int       @default(0)
  url         String
  title       String
  rationale   String
  arxivId     String?
  dismissedAt DateTime?
  createdAt   DateTime

  query  DiscoverQuery @relation(fields: [queryId], references: [id], onDelete: Cascade)
  review Review?

  @@index([queryId, rank])
}
